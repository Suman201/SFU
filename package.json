{
  "name": "native-webrtc-sfu-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Production-oriented native WebRTC SFU platform scaffold with NestJS, Angular, Redis, MongoDB, Coturn, Prometheus, and Kubernetes manifests.",
  "engines": {
    "node": ">=22.22.3",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/contracts",
    "packages/sfu-core",
    "packages/nest-sfu",
    "apps/backend",
    "apps/frontend",
    "apps/admin-portal"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:frontend": "npm run build -w @native-sfu/frontend",
    "build:admin-portal": "npm run build -w @native-sfu/admin-portal",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w @native-sfu/backend",
    "test:browser": "node scripts/patch-playwright-loader.cjs && playwright test",
    "test:browser:chromium": "npm run test:browser -- --project=chromium",
    "test:browser:firefox": "npm run test:browser -- --project=firefox",
    "test:browser:webkit": "npm run test:browser -- --project=webkit",
    "test:browser:operator": "node scripts/patch-playwright-loader.cjs && playwright test tests/browser/operator-incident-workflow.spec.ts --project=chromium",
    "test:browser:staging-turn": "node scripts/patch-playwright-loader.cjs && playwright test tests/browser/staging-turn-validation.spec.ts --project=chromium",
    "test:load:socketio": "k6 run tests/load/socketio-room-flow.js",
    "test:load:node-drain": "k6 run tests/load/node-drain-soak.js",
    "test:live-soak": "node tests/load/live-soak-signoff.mjs",
    "test:live-soak:local": "NODE_A_URL=http://127.0.0.1:3000 NODE_B_URL=http://127.0.0.1:3002 SEED_USER_PASSWORD=Password@12345 OPERATIONS_TOKEN=local-multinode-operations-token-32chars EXPECT_DISTRIBUTED=true EXPECT_PIPE_ENABLED=true REPORT_DIR=reports/live-soak npm run test:live-soak",
    "test:eventing:soak": "node tests/load/eventing-mixed-backlog-soak.mjs",
    "test:staging:preflight": "node tests/load/staging-rollout-preflight.mjs",
    "test:rc": "npm run lint && npm run build && npm run test && npm run test:e2e && npm run test:browser",
    "lint": "npm run lint --workspaces --if-present",
    "seed:dummy-users": "npm run seed:dummy-users -w @native-sfu/backend",
    "seed:dummy-users:multi-node": "MONGODB_URI=mongodb://127.0.0.1:27018/native_sfu SEED_USER_PASSWORD=Password@12345 npm run seed:dummy-users -w @native-sfu/backend",
    "dev:backend": "npm run start:dev -w @native-sfu/backend",
    "dev:frontend": "npm run start -w @native-sfu/frontend",
    "dev:admin-portal": "npm run start -w @native-sfu/admin-portal",
    "verify:build": "npm run build --workspace @native-sfu/contracts && npm run build --workspace @native-sfu/sfu-core && npm run build --workspace @native-sfu/nest-sfu && npm run build --workspace @native-sfu/backend && npm run build --workspace @native-sfu/frontend && npm run build --workspace @native-sfu/admin-portal",
    "verify:dev:backend": "npm run dev:backend",
    "verify:dev:frontend": "npm run dev:frontend",
    "verify:dev:admin": "npm run dev:admin-portal",
    "verify:dev:smoke": "node scripts/dev-runtime-smoke.mjs",
    "docker:up": "docker compose -f infra/docker-compose.dev.yml up --build",
    "docker:down": "docker compose -f infra/docker-compose.dev.yml down --remove-orphans",
    "docker:up:multi-node": "docker compose -f infra/docker-compose.multi-node.yml up --build",
    "docker:start:multi-node": "docker compose -f infra/docker-compose.multi-node.yml up --build -d",
    "docker:down:multi-node": "docker compose -f infra/docker-compose.multi-node.yml down --remove-orphans"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
