# Development-oriented example values. For production, set publicly reachable URLs,
# real TURN URIs, a non-empty OPERATIONS_TOKEN, and secret-manager backed credentials.
# Do not point PUBLIC_URL, NODE_PUBLIC_URL, PIPE_ADVERTISE_IP, TURN_URIS, or ICE_ANNOUNCED_ADDRESS at localhost
# unless every browser, peer node, and operator reaches this node through localhost too.
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
NODE_ID=local-dev-node
NODE_REGION=local
NODE_ZONE=local-a
NODE_PUBLIC_URL=http://localhost:3000
NODE_HEARTBEAT_INTERVAL_MS=5000
NODE_TTL_MS=15000
NODE_DRAINING=false
NODE_PREFER_LOCAL=true
NODE_MAX_ROOMS=1000
NODE_MAX_TRANSPORTS=5000
ENABLE_PIPE_TRANSPORT=false
PIPE_PORT_RANGE=41000-41100
PIPE_CLUSTER_SECRET=
# Required whenever ENABLE_PIPE_TRANSPORT=true outside NODE_ENV=test.
PIPE_ADVERTISE_IP=
PIPE_ALLOWED_NODE_IDS=
PIPE_COORDINATION_TIMEOUT_MS=5000
PIPE_COORDINATION_MAX_ATTEMPTS=3
PIPE_MAX_SETUP_REQUESTS_PER_MINUTE=120
CORS_ALLOWED_ORIGINS=http://localhost:4200
MONGODB_URI=mongodb://127.0.0.1:27017/native_sfu
REDIS_URL=redis://127.0.0.1:6379
REDIS_REQUIRED=true
JWT_ACCESS_SECRET=dev-access-secret-please-rotate-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-please-rotate-32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=native-sfu-auth
JWT_AUDIENCE=native-sfu-clients
OPERATIONS_TOKEN=
TURN_REALM=native-sfu.local
TURN_SECRET=dev-turn-secret-please-rotate-32chars
# Frontend publishers/subscribers fetch these URIs through GET /api/v1/media/turn-credentials.
# Production TURN values must use the public/announced address browsers actually reach.
# The current release candidate supports and advertises UDP TURN URIs only.
TURN_URIS=turn:localhost:3478?transport=udp
# Optional server-side ICE inputs for the backend media plane.
# These drive SFU-side srflx/relay gathering and optional host-candidate public address rewriting.
ICE_STUN_SERVERS=
ICE_TURN_SERVERS=
ICE_ANNOUNCED_ADDRESS=
# Legacy alias for ICE_ANNOUNCED_ADDRESS. Keep them identical when both are set.
ICE_PUBLIC_CANDIDATE_ADDRESS=
# Optional local event-delivery controls. Production should set a dedicated
# WEBHOOK_SECRET_ENCRYPTION_KEY instead of relying on JWT_ACCESS_SECRET fallback for webhook secrets at rest.
WEBHOOK_SECRET_ENCRYPTION_KEY=
WEBHOOK_DELIVERY_ENABLED=true
WEBHOOK_DEFAULT_TIMEOUT_MS=5000
WEBHOOK_DEFAULT_MAX_ATTEMPTS=5
WEBHOOK_DEFAULT_INITIAL_BACKOFF_MS=2000
WEBHOOK_DELIVERY_POLL_INTERVAL_MS=1000
WEBHOOK_DELIVERY_LEASE_MS=30000
# Shared delivery-pump tuning for backlog throughput, per-endpoint fairness, and mixed-adapter isolation.
WEBHOOK_DELIVERY_CONCURRENCY=4
WEBHOOK_DELIVERY_MAX_BATCH_PER_PUMP=16
WEBHOOK_DELIVERY_MAX_CONCURRENT_PER_ENDPOINT=2
# Retention is policy-driven: delivered/cancelled rows age out sooner than
# exhausted rows, and event retention must stay at least as long as delivery retention.
EVENT_LOG_RETENTION_DAYS=30
WEBHOOK_DELIVERY_RETENTION_DAYS=14
WEBHOOK_EXHAUSTED_DELIVERY_RETENTION_DAYS=30
EVENT_RETENTION_CLEANUP_INTERVAL_MS=3600000
# Optional reusable email and browser-push notification providers.
# Providers are disabled by default; production validation requires complete provider config only when enabled.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Native SFU
SMTP_REPLY_TO=
PUSH_ENABLED=false
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@example.com
MEDIA_WORKER_MODE=in-process
MEDIA_WORKER_COUNT=1
HOST_CANDIDATE_PORT_RANGE=40000-40100
MEDIA_WORKER_REQUEST_TIMEOUT_MS=5000
MEDIA_WORKER_STARTUP_TIMEOUT_MS=10000
MEDIA_WORKER_HEARTBEAT_INTERVAL_MS=2000
MEDIA_WORKER_HEARTBEAT_TIMEOUT_MS=6000
MEDIA_WORKER_RESTART_BACKOFF_MS=1000
MEDIA_WORKER_DRAIN_TIMEOUT_MS=30000
MEDIA_WORKER_MAX_ROOMS_PER_WORKER=100
MEDIA_WORKER_MAX_TRANSPORTS_PER_WORKER=500
MEDIA_WORKER_MAX_INFLIGHT_REQUESTS_PER_WORKER=1000
MEDIA_WORKER_SOFT_IPC_LATENCY_MS=100
MEDIA_WORKER_HARD_IPC_LATENCY_MS=1000
MEDIA_WORKER_SOFT_MEMORY_LIMIT_BYTES=
MEDIA_WORKER_HARD_MEMORY_LIMIT_BYTES=
MEDIA_WORKER_SOFT_RTP_PACKET_RATE=50000
MEDIA_WORKER_SOFT_RTCP_PACKET_RATE=5000
RECORDING_STORAGE_DRIVER=local
RECORDING_LOCAL_PATH=/app/recordings
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
SWAGGER_ENABLED=true
SWAGGER_TITLE=EduConnect Live Backend API
SWAGGER_VERSION=0.1.0
SWAGGER_PATH=api/docs
METRICS_ENABLED=true
METRICS_PATH=metrics
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeThisAdminPassword123!
