NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
MONGODB_URI=mongodb://mongo:27017/native_sfu
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
TURN_REALM=native-sfu.local
TURN_SECRET=replace-with-turn-rest-secret
TURN_URIS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
RECORDING_STORAGE_DRIVER=local
RECORDING_LOCAL_PATH=/app/recordings
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
