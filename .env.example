NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
NODE_ID=local-dev-node
NODE_REGION=local
NODE_ZONE=local-a
NODE_PUBLIC_URL=http://localhost:3000
NODE_HEARTBEAT_INTERVAL_MS=5000
NODE_TTL_MS=15000
NODE_DRAINING=false
NODE_PREFER_LOCAL=true
NODE_MAX_ROOMS=1000
NODE_MAX_TRANSPORTS=5000
ENABLE_PIPE_TRANSPORT=false
PIPE_PORT_RANGE=41000-41100
PIPE_CLUSTER_SECRET=
# Required whenever ENABLE_PIPE_TRANSPORT=true outside NODE_ENV=test.
PIPE_ADVERTISE_IP=
PIPE_ALLOWED_NODE_IDS=
PIPE_COORDINATION_TIMEOUT_MS=5000
PIPE_COORDINATION_MAX_ATTEMPTS=3
PIPE_MAX_SETUP_REQUESTS_PER_MINUTE=120
CORS_ALLOWED_ORIGINS=http://localhost:4200
MONGODB_URI=mongodb://mongo:27017/native_sfu
REDIS_URL=redis://redis:6379
REDIS_REQUIRED=true
JWT_ACCESS_SECRET=dev-access-secret-please-rotate-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-please-rotate-32chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=native-sfu-auth
JWT_AUDIENCE=native-sfu-clients
TURN_REALM=native-sfu.local
TURN_SECRET=dev-turn-secret-please-rotate-32chars
TURN_URIS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
MEDIA_WORKER_MODE=in-process
MEDIA_WORKER_COUNT=1
MEDIA_WORKER_REQUEST_TIMEOUT_MS=5000
MEDIA_WORKER_STARTUP_TIMEOUT_MS=10000
MEDIA_WORKER_HEARTBEAT_INTERVAL_MS=2000
MEDIA_WORKER_HEARTBEAT_TIMEOUT_MS=6000
MEDIA_WORKER_RESTART_BACKOFF_MS=1000
MEDIA_WORKER_DRAIN_TIMEOUT_MS=30000
MEDIA_WORKER_MAX_ROOMS_PER_WORKER=100
MEDIA_WORKER_MAX_TRANSPORTS_PER_WORKER=500
MEDIA_WORKER_MAX_INFLIGHT_REQUESTS_PER_WORKER=1000
MEDIA_WORKER_SOFT_IPC_LATENCY_MS=100
MEDIA_WORKER_HARD_IPC_LATENCY_MS=1000
MEDIA_WORKER_SOFT_MEMORY_LIMIT_BYTES=
MEDIA_WORKER_HARD_MEMORY_LIMIT_BYTES=
MEDIA_WORKER_SOFT_RTP_PACKET_RATE=50000
MEDIA_WORKER_SOFT_RTCP_PACKET_RATE=5000
RECORDING_STORAGE_DRIVER=local
RECORDING_LOCAL_PATH=/app/recordings
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
SWAGGER_TITLE=EduConnect Live Backend API
SWAGGER_VERSION=0.1.0
SWAGGER_PATH=api/docs
METRICS_PATH=metrics
